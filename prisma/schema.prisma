// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
//  LEGACY MODELS (bestehend, unverändert)
// ═══════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
//  AI NEWS — Tägliche kuratierte KI-News
//  Siehe ai-news/DATABASE-SCHEMA.md für Doku
// ═══════════════════════════════════════════════════════════

model AiNewsSummary {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique
  summaryDe   String
  summaryEn   String?
  createdAt   DateTime @default(now())

  items       AiNewsItem[]

  @@map("ai_news_summaries")
}

model AiNewsItem {
  id              Int      @id @default(autoincrement())
  summaryId       Int
  position        Int
  headline        String
  headlineDe      String?  // Deutsche Übersetzung der Headline (für DE-Anzeige)
  headlineEn      String?  // Englische Übersetzung der Headline (für EN-Anzeige)
  descriptionDe   String
  descriptionEn   String?
  source          String
  sourceUrl       String
  thumbnailUrl    String?
  languageOrig    String   @default("en")
  category        String?  // "research|business|regulation|tools|society"
  createdAt       DateTime @default(now())

  summary         AiNewsSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([summaryId])
  @@index([position])
  @@map("ai_news_items")
}

// ═══════════════════════════════════════════════════════════
//  NEWSLETTER — Subscriber-Verwaltung
// ═══════════════════════════════════════════════════════════

model NewsletterSubscriber {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  language        String    @default("de")  // Newsletter-Sprache (DE/EN)
  newsLanguages   String    @default("de,en")  // Welche News-Sprachen (de,en,zh,ja,fr)
  frequency       String    @default("daily")
  confirmToken    String    @unique
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  lastSentDate    DateTime?
  createdAt       DateTime  @default(now())

  @@index([email])
  @@index([language, frequency])
  @@map("newsletter_subscribers")
}

// ═══════════════════════════════════════════════════════════
//  WORKFLOW-RUNS — n8n-Monitoring (optional)
// ═══════════════════════════════════════════════════════════

model WorkflowRun {
  id           Int       @id @default(autoincrement())
  workflowId   String
  runAt        DateTime
  status       String
  itemCount    Int?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([workflowId, runAt])
  @@map("workflow_runs")
}
